        <mxCell id="X2dEJGTSvtpbcQZdQA9n-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Design a Whatsapp system with proper folllowing requirement’s:&lt;div&gt;1. User Service&lt;/div&gt;&lt;div&gt;2. Chat Service&lt;/div&gt;&lt;div&gt;3. Group Service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Optimize the chat service for handling the millions of request.&lt;/div&gt;&lt;div&gt;Specify the type of connection used in the design&lt;/div&gt;&lt;div&gt;Determine how the designing will be done for LAST SEEN functionality&amp;nbsp;&lt;br&gt;Impliment CDC pipeline in the same architecture .&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="760" x="70" y="60" as="geometry" />
        </mxCell>
        <mxCell id="X2dEJGTSvtpbcQZdQA9n-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Funtional Requirements:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Client should be able to register and login.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. Client should be able to send message and receive messages.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3.&amp;nbsp; Client should be able to do group messagng.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4. Client should be able to sent files (such as media files and others).&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;5. System should maintain chat history.&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="420" x="270" y="270" as="geometry" />
        </mxCell>
        <mxCell id="X2dEJGTSvtpbcQZdQA9n-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Million of Users" vertex="1">
          <mxGeometry height="30" width="60" x="-130" y="1125" as="geometry" />
        </mxCell>
        <mxCell id="X2dEJGTSvtpbcQZdQA9n-13" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.gateway_load_balancer;" value="" vertex="1">
          <mxGeometry height="80" width="80" x="290" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="X2dEJGTSvtpbcQZdQA9n-30" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Non-Functional Requirements:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Scalability: Chat service should be able to handle millions of request.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. CAP Theorem:&amp;nbsp; &amp;nbsp;Availability &amp;gt;&amp;gt;&amp;gt;&amp;gt; Consistency&amp;nbsp;&lt;br&gt;&lt;br&gt;3. Latency: 200 - 300ms&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4. System should be reliable&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
